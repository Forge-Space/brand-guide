---
import BaseLayout from "@/layouts/BaseLayout.astro";

const logoVariants = ["wordmark", "monogram", "abstract", "icon", "wordmark-blue", "wordmark-purple", "wordmark-white"] as const;
const formats = ["svg", "png", "webp"] as const;
---

<BaseLayout title="Assets">
  <header class="mb-12">
    <h1 class="font-heading text-4xl font-bold mb-3">Assets</h1>
    <p class="text-text-secondary max-w-xl">
      Download brand assets for use in your project, marketing materials, or documentation.
      Prefer SVG for web; use PNG or WEBP for social previews and app icons.
    </p>
  </header>

  <!-- Logos -->
  <section class="mb-16">
    <h2 class="text-xs text-text-muted uppercase tracking-wider mb-6">Logos</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {logoVariants.map((variant) => (
        <div class="bg-surface-2 rounded-xl p-6 flex flex-col items-center gap-4 border border-white/5">
          <img src={`/logos/${variant}.svg`} alt={variant} class="w-20 h-20 object-contain" />
          <div class="text-center w-full">
            <p class="text-sm font-medium capitalize mb-2">{variant.replace("-", " ")}</p>
            <div class="flex flex-wrap justify-center gap-x-2 gap-y-1 text-[11px]">
              {formats.map((ext) => (
                <a href={`/logos/${variant}.${ext}`} download class="text-text-muted hover:text-white transition-colors">{ext.toUpperCase()}</a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Favicons -->
  <section class="mb-16">
    <h2 class="text-xs text-text-muted uppercase tracking-wider mb-6">Favicons</h2>
    <div class="bg-white/5 rounded-xl p-6 border border-white/5">
      <div class="flex items-end gap-6 mb-6">
        <div class="flex flex-col items-center gap-2">
          <div class="w-4 h-4 bg-surface-2 rounded-sm flex items-center justify-center">
            <img src="/favicons/favicon-sizes.svg" alt="" class="w-4 h-4" />
          </div>
          <code class="text-[10px] font-mono text-text-muted">16</code>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-8 h-8 bg-surface-2 rounded flex items-center justify-center">
            <img src="/favicons/favicon-sizes.svg" alt="" class="w-8 h-8" />
          </div>
          <code class="text-[10px] font-mono text-text-muted">32</code>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 bg-surface-2 rounded-lg flex items-center justify-center">
            <img src="/favicons/favicon-sizes.svg" alt="" class="w-12 h-12" />
          </div>
          <code class="text-[10px] font-mono text-text-muted">180</code>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-16 h-16 bg-surface-2 rounded-xl flex items-center justify-center">
            <img src="/favicons/favicon-sizes.svg" alt="" class="w-16 h-16" />
          </div>
          <code class="text-[10px] font-mono text-text-muted">512</code>
        </div>
      </div>
      <div class="flex flex-wrap gap-2">
        {formats.map((ext) => (
          <a
            href={`/favicons/favicon-sizes.${ext}`}
            download
            class="inline-flex items-center gap-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-lg px-4 py-2 text-sm transition-colors"
          >
            <span class="text-text-muted">↓</span>
            {ext.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- OG Images -->
  <section class="mb-16">
    <h2 class="text-xs text-text-muted uppercase tracking-wider mb-6">Open Graph Images</h2>
    <p class="text-text-secondary text-sm mb-4 max-w-xl">
      Default and Article OG images use a 1200 × 630 canvas; Social uses 1200 × 1200. Key content (logo and text) stays comfortably inside an approximate 80px safe inset on all sides so platform crops don&apos;t clip anything important. Background treatment uses a flat `#121214` base with a subtle centered purple blur and a thin inset frame for stronger brand identity. Logo and wordmark use the main brand purple palette (not white) for clear contrast on the blur; layout is a horizontal lockup (icon left, text right). Typography: Sora for heading/wordmark and DM Sans for supporting copy.
    </p>
    <div class="space-y-6">
      {[
        { base: "default", label: "Default", size: "1200 × 630" },
        { base: "article", label: "Article", size: "1200 × 630" },
        { base: "social", label: "Social", size: "1200 × 1200" },
      ].map(({ base, label, size }) => (
        <div>
          <div class="bg-surface-2 rounded-xl overflow-hidden border border-white/5">
            <img src={`/og/${base}.svg`} alt={`${label} OG image`} class="w-full max-h-[200px] object-cover" />
          </div>
          <div class="flex items-center justify-between mt-3">
            <div>
              <p class="text-sm font-medium">{label}</p>
              <p class="text-xs text-text-muted">{size}px</p>
            </div>
            <div class="flex gap-2">
              {formats.map((ext) => (
                <a
                  href={`/og/${base}.${ext}`}
                  download
                  class="text-xs text-text-muted hover:text-white bg-white/5 hover:bg-white/10 px-3 py-1.5 rounded-md transition-colors"
                >
                  {ext.toUpperCase()} ↓
                </a>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
    <p class="text-xs text-text-muted mt-3 max-w-xl">
      After updating OG assets, remember to refresh caches on platforms like LinkedIn, Facebook, and Twitter/X using their preview/debug tools so new images appear in link previews.
    </p>
  </section>

  <!-- Design tokens -->
  <section>
    <h2 class="text-xs text-text-muted uppercase tracking-wider mb-6">Design Token Packages</h2>
    <div class="space-y-3">
      {[
        { href: "/downloads/tokens.json", label: "W3C Design Tokens (JSON)", desc: "Industry-standard token format, compatible with Style Dictionary and Figma" },
        { href: "/downloads/tailwind-preset.js", label: "Tailwind CSS Preset", desc: "Drop into your tailwind.config.ts as a preset" },
        { href: "/downloads/tokens.scss", label: "Sass Variables", desc: "Sass variable definitions for traditional CSS workflows" },
        { href: "/downloads/theme.ts", label: "React Theme (TypeScript)", desc: "Typed theme object for styled-components, Emotion, or custom theming" },
      ].map(({ href, label, desc }) => (
        <a
          href={href}
          download
          class="flex items-center justify-between bg-white/[0.03] hover:bg-white/[0.06] border border-white/5 hover:border-white/10 rounded-xl p-4 transition-all group"
        >
          <div>
            <p class="text-sm font-medium group-hover:text-brand-accent transition-colors">{label}</p>
            <p class="text-xs text-text-muted mt-0.5">{desc}</p>
          </div>
          <span class="text-text-muted group-hover:text-white text-sm transition-colors shrink-0 ml-4">↓</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
