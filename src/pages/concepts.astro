---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const dir = join(process.cwd(), "public", "logos", "concepts");
const load = (file: string) => readFileSync(join(dir, file), "utf-8");

const finalists = [
  { id: "flame", file: "af6-flame-rise.svg", name: "Flame Rise", desc: "Amber / Blue / Purple — fire rises, natural convection. The full-color mark.", color: "#F59E0B" },
  { id: "blue", file: "af-hrc4-blue-tint.svg", name: "Blue Tint", desc: "Three blue shades: deep → medium → light. Monochrome reliability.", color: "#3B82F6" },
  { id: "purple", file: "af-hrc6-purple-tint.svg", name: "Purple Tint", desc: "Three purple shades: primary → medium → light. The brand-color monochrome.", color: "#7C3AED" },
  { id: "white", file: "af-white.svg", name: "Full White", desc: "Solid white. For dark backgrounds, overlays, and reversed contexts.", color: "#FFFFFF" },
] as const;

const svgs = Object.fromEntries(
  finalists.map((c) => [c.id, load(c.file)])
);

const sizes = [64, 48, 32, 24, 20, 16] as const;

const backgrounds = [
  { name: "Dark (app)", bg: "bg-surface-0", labelClass: "text-white/40" },
  { name: "Surface", bg: "bg-surface-2", labelClass: "text-white/40" },
  { name: "White", bg: "bg-white", labelClass: "text-black/40" },
  { name: "Pure Black", bg: "bg-black", labelClass: "text-white/30" },
  { name: "Amber", bg: "", style: "background: #F59E0B", labelClass: "text-black/50" },
  { name: "Purple", bg: "", style: "background: #7C3AED", labelClass: "text-white/50" },
  { name: "Blue", bg: "", style: "background: #3B82F6", labelClass: "text-white/50" },
  { name: "Hero Gradient", bg: "", style: "background: linear-gradient(135deg, #7C3AED 0%, #3B82F6 100%)", labelClass: "text-white/50" },
] as const;
---

<BaseLayout title="Logo Finalists">
  <header class="mb-12">
    <h1 class="font-heading text-4xl font-bold mb-3">Logo Finalists</h1>
    <p class="text-text-secondary max-w-xl">
      Four marks, one system. Each serves a context —
      full-color, monochrome blue, monochrome purple, and reversed white.
    </p>
  </header>

  <!-- Hero cards -->
  <section class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-20">
    {finalists.map((f) => (
      <div>
        <div class="bg-surface-2 rounded-xl border border-white/5 overflow-hidden">
          <div class="p-12 flex items-center justify-center">
            <div class="w-28 h-28" set:html={svgs[f.id]} />
          </div>
          <div class="bg-white p-8 flex items-center justify-center border-t border-white/5">
            <div class="w-20 h-20" set:html={svgs[f.id]} />
          </div>
        </div>
        <div class="mt-4">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full" style={`background: ${f.color}`} />
            <h3 class="font-heading font-bold">{f.name}</h3>
          </div>
          <p class="text-xs text-text-secondary mt-1">{f.desc}</p>
        </div>
      </div>
    ))}
  </section>

  <!-- Size scaling -->
  <section class="mb-20">
    <h2 class="font-heading text-xl font-bold mb-2">Size Scaling</h2>
    <p class="text-text-secondary text-sm mb-6">Every mark at 64 → 16px. Does it hold?</p>

    <div class="space-y-8">
      {/* Dark background */}
      <div class="bg-surface-2 rounded-xl p-8 border border-white/5">
        <span class="text-[10px] text-text-muted font-mono uppercase tracking-wider mb-4 block">Dark</span>
        {finalists.map((f) => (
          <div class="flex items-center gap-6 mb-4 last:mb-0">
            <span class="text-[10px] text-text-muted font-mono w-20 shrink-0">{f.name}</span>
            <div class="flex items-end gap-5">
              {sizes.map((s) => (
                <div class="text-center">
                  <div style={`width: ${s}px; height: ${s}px`} set:html={svgs[f.id]} />
                  <span class="text-[8px] text-text-muted font-mono mt-1 block">{s}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      {/* White background */}
      <div class="bg-white rounded-xl p-8">
        <span class="text-[10px] text-black/40 font-mono uppercase tracking-wider mb-4 block">Light</span>
        {finalists.map((f) => (
          <div class="flex items-center gap-6 mb-4 last:mb-0">
            <span class="text-[10px] text-black/40 font-mono w-20 shrink-0">{f.name}</span>
            <div class="flex items-end gap-5">
              {sizes.map((s) => (
                <div class="text-center">
                  <div style={`width: ${s}px; height: ${s}px`} set:html={svgs[f.id]} />
                  <span class="text-[8px] text-black/30 font-mono mt-1 block">{s}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Background matrix -->
  <section class="mb-20">
    <h2 class="font-heading text-xl font-bold mb-2">Background Matrix</h2>
    <p class="text-text-secondary text-sm mb-6">Every mark on every surface.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {backgrounds.map((bg) => (
        <div class={`rounded-xl p-8 ${bg.bg}`} style={bg.style ?? ""}>
          <span class={`text-[10px] font-mono uppercase tracking-wider mb-4 block ${bg.labelClass}`}>{bg.name}</span>
          <div class="flex items-center justify-around">
            {finalists.map((f) => (
              <div class="text-center">
                <div class="w-12 h-12" set:html={svgs[f.id]} />
                <span class={`text-[8px] font-mono mt-1.5 block ${bg.labelClass}`}>{f.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Side by side at production sizes -->
  <section class="mb-20">
    <h2 class="font-heading text-xl font-bold mb-2">In Context</h2>
    <p class="text-text-secondary text-sm mb-6">How they'd appear in real UI.</p>

    <div class="space-y-6">
      {/* Nav bar - dark */}
      <div class="bg-surface-1 rounded-xl px-6 py-4 flex items-center gap-4 border border-white/5">
        <div class="w-8 h-8" set:html={svgs["flame"]} />
        <span class="font-heading font-bold text-sm">Forge Space</span>
        <div class="flex-1" />
        <span class="text-xs text-text-muted">Dashboard</span>
        <span class="text-xs text-text-muted">Generate</span>
        <span class="text-xs text-text-muted">History</span>
      </div>

      {/* Nav bar - white */}
      <div class="bg-white rounded-xl px-6 py-4 flex items-center gap-4">
        <div class="w-8 h-8" set:html={svgs["purple"]} />
        <span class="font-heading font-bold text-sm text-gray-900">Forge Space</span>
        <div class="flex-1" />
        <span class="text-xs text-gray-500">Dashboard</span>
        <span class="text-xs text-gray-500">Generate</span>
        <span class="text-xs text-gray-500">History</span>
      </div>

      {/* Hero banner */}
      <div class="rounded-xl p-12 flex flex-col items-center justify-center text-center" style="background: linear-gradient(135deg, #7C3AED 0%, #3B82F6 100%)">
        <div class="w-16 h-16 mb-4" set:html={svgs["white"]} />
        <span class="font-heading font-bold text-2xl text-white">Forge Space</span>
        <span class="text-sm text-white/70 mt-1">The developer tools ecosystem.</span>
      </div>

      {/* Footer - dark */}
      <div class="bg-black rounded-xl px-8 py-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-6 h-6" set:html={svgs["white"]} />
          <span class="text-xs text-white/50 font-mono">Forge Space</span>
        </div>
        <span class="text-xs text-white/30">2026</span>
      </div>

      {/* Favicon row */}
      <div class="bg-surface-2 rounded-xl p-6 border border-white/5">
        <span class="text-[10px] text-text-muted font-mono uppercase tracking-wider mb-4 block">Favicon (16px)</span>
        <div class="flex items-center gap-8">
          {finalists.map((f) => (
            <div class="flex items-center gap-2">
              <div class="w-4 h-4 rounded-sm bg-surface-1 p-px flex items-center justify-center">
                <div class="w-4 h-4" set:html={svgs[f.id]} />
              </div>
              <span class="text-[10px] text-text-muted font-mono">{f.name}</span>
            </div>
          ))}
        </div>
      </div>

      {/* App icon */}
      <div class="flex gap-6">
        {finalists.map((f) => (
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-surface-2 border border-white/5 flex items-center justify-center p-3">
              <div class="w-10 h-10" set:html={svgs[f.id]} />
            </div>
            <span class="text-[9px] text-text-muted font-mono mt-2 block">{f.name}</span>
          </div>
        ))}
        {/* Amber bg app icon */}
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center p-3" style="background: #F59E0B">
            <div class="w-10 h-10" set:html={svgs["white"]} />
          </div>
          <span class="text-[9px] text-text-muted font-mono mt-2 block">White on Amber</span>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center p-3" style="background: #7C3AED">
            <div class="w-10 h-10" set:html={svgs["white"]} />
          </div>
          <span class="text-[9px] text-text-muted font-mono mt-2 block">White on Purple</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Usage guide -->
  <section>
    <h2 class="font-heading text-xl font-bold mb-2">Usage Guide</h2>
    <div class="bg-surface-2 rounded-xl p-6 border border-white/5 text-sm text-text-secondary space-y-3">
      <div class="flex gap-3 items-start">
        <div class="w-6 h-6 shrink-0 mt-0.5" set:html={svgs["flame"]} />
        <div><span class="text-text-primary font-medium">Flame Rise</span> — Primary mark. Use on dark app surfaces, marketing, social. The full brand story.</div>
      </div>
      <div class="flex gap-3 items-start">
        <div class="w-6 h-6 shrink-0 mt-0.5" set:html={svgs["blue"]} />
        <div><span class="text-text-primary font-medium">Blue Tint</span> — Secondary monochrome. Use when color is limited or alongside blue UI elements.</div>
      </div>
      <div class="flex gap-3 items-start">
        <div class="w-6 h-6 shrink-0 mt-0.5" set:html={svgs["purple"]} />
        <div><span class="text-text-primary font-medium">Purple Tint</span> — Brand monochrome. Use on light backgrounds, docs, print where purple reads well.</div>
      </div>
      <div class="flex gap-3 items-start">
        <div class="w-6 h-6 shrink-0 mt-0.5 bg-surface-4 rounded p-0.5" set:html={svgs["white"]} />
        <div><span class="text-text-primary font-medium">Full White</span> — Reversed. Use on gradients, photos, dark overlays, video. Never on white backgrounds.</div>
      </div>
    </div>
  </section>
</BaseLayout>
