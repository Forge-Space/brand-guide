---
import BaseLayout from "@/layouts/BaseLayout.astro";

const primary = "#7C3AED";

const palettes = {
  amber: {
    name: "Amber Fire",
    tagline: "The forge burns bright",
    secondary: "#3B82F6",
    accent: "#F59E0B",
    secondaryName: "Blue",
    accentName: "Amber",
  },
  rose: {
    name: "Sky + Rose",
    tagline: "Clean, modern, product",
    secondary: "#0EA5E9",
    accent: "#F43F5E",
    secondaryName: "Sky Blue",
    accentName: "Rose",
  },
};

const ids = ["amber", "rose"] as const;
---

<BaseLayout title="Amber Fire vs Sky + Rose">
  <header class="mb-12">
    <h1 class="font-heading text-4xl font-bold mb-3">Head to Head</h1>
    <p class="text-text-secondary max-w-xl">
      Two finalists. Same primary <span class="font-mono text-sm" style={`color: ${primary}`}>#7C3AED</span>. Which one is Forge Space?
    </p>
  </header>

  <!-- Swatch comparison -->
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div>
          <h2 class="font-heading text-lg font-bold mb-1">{p.name}</h2>
          <p class="text-xs text-text-muted mb-4">{p.tagline}</p>
          <div class="flex gap-2">
            <div class="flex-1 h-16 rounded-lg" style={`background: ${primary}`}></div>
            <div class="flex-1 h-16 rounded-lg" style={`background: ${p.secondary}`}></div>
            <div class="flex-1 h-16 rounded-lg" style={`background: ${p.accent}`}></div>
          </div>
          <div class="flex gap-2 mt-1.5">
            <span class="flex-1 text-[10px] text-text-muted font-mono text-center">Primary</span>
            <span class="flex-1 text-[10px] text-text-muted font-mono text-center">{p.secondaryName}</span>
            <span class="flex-1 text-[10px] text-text-muted font-mono text-center">{p.accentName}</span>
          </div>
        </div>
      );
    })}
  </section>

  <!-- Hero / Landing section -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">Landing Hero</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="rounded-xl overflow-hidden" style={`background: linear-gradient(135deg, ${primary} 0%, ${p.secondary} 100%)`}>
          <div class="p-8 text-center">
            <div class="flex justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 64 64" fill="none">
                <path d="M14 8 h46 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H14 L8 14 L14 8 Z" fill="white"/>
                <rect x="22" y="24" width="24" height="12" rx="2" fill="white"/>
                <rect x="16" y="40" width="38" height="14" rx="3" fill="white"/>
              </svg>
            </div>
            <div class="text-white font-heading font-bold text-lg mb-1">Generate. Integrate. Ship.</div>
            <div class="text-white/60 text-xs mb-4">AI-powered UI generation for modern teams</div>
            <div class="flex justify-center gap-2">
              <button class="px-4 py-1.5 rounded-lg text-xs font-bold" style={`background: ${p.accent}; color: white`}>Get Started</button>
              <button class="px-4 py-1.5 rounded-lg text-xs font-medium border border-white/30 text-white">Learn More</button>
            </div>
          </div>
        </div>
      );
    })}
  </section>

  <!-- App shell mockup -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">App Shell — Dark</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="bg-[#0F0F14] rounded-xl overflow-hidden border border-white/5">
          {/* Top nav */}
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-white/5">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 64 64" fill="none">
                <path d="M14 8 h46 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H14 L8 14 L14 8 Z" fill={primary}/>
                <rect x="22" y="24" width="24" height="12" rx="2" fill={primary}/>
                <rect x="16" y="40" width="38" height="14" rx="3" fill={primary}/>
              </svg>
              <span class="text-white text-xs font-heading font-bold">Siza</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] text-white/40">Projects</span>
              <span class="text-[10px] text-white/40">Templates</span>
              <span class="text-[10px] font-bold" style={`color: ${p.accent}`}>Upgrade</span>
              <div class="w-5 h-5 rounded-full bg-white/10"></div>
            </div>
          </div>

          <div class="flex">
            {/* Sidebar */}
            <div class="w-36 border-r border-white/5 p-3 space-y-1">
              <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-[10px] text-white/80" style={`background: ${primary}20`}>
                <div class="w-1.5 h-1.5 rounded-full" style={`background: ${primary}`}></div>
                Generator
              </div>
              <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-[10px] text-white/40">
                <div class="w-1.5 h-1.5 rounded-full bg-white/20"></div>
                Templates
              </div>
              <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-[10px] text-white/40">
                <div class="w-1.5 h-1.5 rounded-full bg-white/20"></div>
                History
              </div>
              <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-[10px] text-white/40">
                <div class="w-1.5 h-1.5 rounded-full bg-white/20"></div>
                Settings
              </div>
              <div class="border-t border-white/5 pt-2 mt-2">
                <div class="px-2 py-1.5 text-[10px] font-medium" style={`color: ${p.secondary}`}>Pro Plan</div>
                <div class="px-2 text-[9px] text-white/30">247 / 500 generations</div>
                <div class="mx-2 mt-1 h-1 bg-white/10 rounded-full overflow-hidden">
                  <div class="h-full rounded-full" style={`width: 49%; background: ${p.secondary}`}></div>
                </div>
              </div>
            </div>

            {/* Main content */}
            <div class="flex-1 p-4">
              {/* Prompt area */}
              <div class="bg-white/5 rounded-lg p-3 mb-3 border border-white/5">
                <div class="text-[10px] text-white/30 mb-2">Describe your component...</div>
                <div class="flex justify-between items-center">
                  <div class="flex gap-1.5">
                    <span class="px-1.5 py-0.5 rounded text-[9px] bg-white/5 text-white/40">React</span>
                    <span class="px-1.5 py-0.5 rounded text-[9px] bg-white/5 text-white/40">Tailwind</span>
                  </div>
                  <button class="px-3 py-1 rounded-md text-[10px] font-bold text-white" style={`background: ${p.accent}`}>Generate</button>
                </div>
              </div>

              {/* Results grid */}
              <div class="grid grid-cols-2 gap-2">
                <div class="bg-white/5 rounded-lg p-3 border border-white/5">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-[10px] font-bold text-white/80">LoginForm.tsx</span>
                    <span class="px-1.5 py-0.5 rounded text-[8px] font-medium text-white" style={`background: ${p.secondary}`}>New</span>
                  </div>
                  <div class="h-12 bg-white/3 rounded" style="background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.03) 3px, rgba(255,255,255,0.03) 4px)"></div>
                </div>
                <div class="bg-white/5 rounded-lg p-3 border border-white/5">
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-[10px] font-bold text-white/80">PricingCard.tsx</span>
                    <span class="px-1.5 py-0.5 rounded text-[8px] font-medium text-white/50 bg-white/5">Saved</span>
                  </div>
                  <div class="h-12 bg-white/3 rounded" style="background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(255,255,255,0.03) 3px, rgba(255,255,255,0.03) 4px)"></div>
                </div>
              </div>

              {/* Toast / notification */}
              <div class="mt-3 flex items-center gap-2 px-3 py-2 rounded-lg border" style={`border-color: ${p.accent}40; background: ${p.accent}10`}>
                <div class="w-1.5 h-1.5 rounded-full" style={`background: ${p.accent}`}></div>
                <span class="text-[10px]" style={`color: ${p.accent}`}>Component generated successfully</span>
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </section>

  <!-- App shell light -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">App Shell — Light</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="bg-white rounded-xl overflow-hidden border border-zinc-200">
          {/* Top nav light */}
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-zinc-100">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 64 64" fill="none">
                <path d="M14 8 h46 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H14 L8 14 L14 8 Z" fill={primary}/>
                <rect x="22" y="24" width="24" height="12" rx="2" fill={primary}/>
                <rect x="16" y="40" width="38" height="14" rx="3" fill={primary}/>
              </svg>
              <span class="text-zinc-900 text-xs font-heading font-bold">Siza</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] text-zinc-400">Projects</span>
              <span class="text-[10px] text-zinc-400">Templates</span>
              <span class="text-[10px] font-bold" style={`color: ${p.accent}`}>Upgrade</span>
            </div>
          </div>

          <div class="p-4">
            {/* Buttons on light */}
            <div class="flex flex-wrap gap-2 mb-4">
              <button class="px-3 py-1.5 rounded-lg text-white text-[10px] font-medium" style={`background: ${primary}`}>Primary</button>
              <button class="px-3 py-1.5 rounded-lg text-white text-[10px] font-medium" style={`background: ${p.secondary}`}>Secondary</button>
              <button class="px-3 py-1.5 rounded-lg text-white text-[10px] font-bold" style={`background: ${p.accent}`}>CTA</button>
              <button class="px-3 py-1.5 rounded-lg text-[10px] font-medium border" style={`color: ${primary}; border-color: ${primary}40`}>Ghost</button>
            </div>

            {/* Cards on light */}
            <div class="flex gap-2 mb-4">
              <div class="flex-1 rounded-lg p-3 border border-zinc-100">
                <div class="text-[10px] font-bold text-zinc-700 mb-1">Free</div>
                <div class="text-lg font-heading font-bold text-zinc-900">$0</div>
                <div class="text-[9px] text-zinc-400 mb-2">10 gen/month</div>
                <button class="w-full py-1 rounded text-[9px] font-medium border" style={`color: ${primary}; border-color: ${primary}40`}>Current</button>
              </div>
              <div class="flex-1 rounded-lg p-3 border-2" style={`border-color: ${p.accent}`}>
                <div class="flex items-center gap-1">
                  <div class="text-[10px] font-bold text-zinc-700">Pro</div>
                  <span class="px-1 py-0.5 rounded text-[8px] font-bold text-white" style={`background: ${p.accent}`}>Popular</span>
                </div>
                <div class="text-lg font-heading font-bold text-zinc-900">$19</div>
                <div class="text-[9px] text-zinc-400 mb-2">500 gen/month</div>
                <button class="w-full py-1 rounded text-[9px] font-bold text-white" style={`background: ${p.accent}`}>Upgrade</button>
              </div>
              <div class="flex-1 rounded-lg p-3 border border-zinc-100">
                <div class="text-[10px] font-bold text-zinc-700">Team</div>
                <div class="text-lg font-heading font-bold text-zinc-900">$49</div>
                <div class="text-[9px] text-zinc-400 mb-2">Unlimited</div>
                <button class="w-full py-1 rounded text-[9px] font-medium text-white" style={`background: ${p.secondary}`}>Contact</button>
              </div>
            </div>

            {/* Links / text on light */}
            <div class="flex gap-4 text-[10px]">
              <a style={`color: ${primary}`} class="font-medium">Primary link</a>
              <a style={`color: ${p.secondary}`} class="font-medium">Secondary link</a>
              <a style={`color: ${p.accent}`} class="font-medium">Accent link</a>
            </div>
          </div>
        </div>
      );
    })}
  </section>

  <!-- Email / Newsletter -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">Email Template</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="bg-zinc-100 rounded-xl p-4">
          <div class="max-w-[280px] mx-auto bg-white rounded-lg overflow-hidden shadow-sm">
            <div class="h-2" style={`background: linear-gradient(90deg, ${primary}, ${p.secondary})`}></div>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 64 64" fill="none">
                  <path d="M14 8 h46 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H14 L8 14 L14 8 Z" fill={primary}/>
                  <rect x="22" y="24" width="24" height="12" rx="2" fill={primary}/>
                  <rect x="16" y="40" width="38" height="14" rx="3" fill={primary}/>
                </svg>
                <span class="text-[11px] font-heading font-bold text-zinc-900">Siza</span>
              </div>
              <div class="text-sm font-heading font-bold text-zinc-900 mb-1">Your component is ready</div>
              <div class="text-[10px] text-zinc-500 mb-3 leading-relaxed">
                The LoginForm component you requested has been generated and is ready for review.
              </div>
              <button class="w-full py-2 rounded-lg text-xs font-bold text-white mb-2" style={`background: ${p.accent}`}>View Component</button>
              <button class="w-full py-2 rounded-lg text-xs font-medium border border-zinc-200 text-zinc-600">View in Dashboard</button>
              <div class="border-t border-zinc-100 mt-4 pt-3">
                <div class="text-[9px] text-zinc-400 text-center">
                  <span style={`color: ${p.secondary}`}>247 of 500</span> generations used this month
                </div>
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </section>

  <!-- Social / OG Image -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">Social / OG Image</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="rounded-xl overflow-hidden aspect-[1.91/1]" style={`background: linear-gradient(135deg, ${primary} 0%, ${p.secondary} 60%, ${p.accent} 100%)`}>
          <div class="h-full flex flex-col justify-between p-6">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 64 64" fill="none">
                <path d="M14 8 h46 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H14 L8 14 L14 8 Z" fill="white"/>
                <rect x="22" y="24" width="24" height="12" rx="2" fill="white"/>
                <rect x="16" y="40" width="38" height="14" rx="3" fill="white"/>
              </svg>
              <span class="text-white font-heading font-bold text-sm">Siza</span>
            </div>
            <div>
              <div class="text-white font-heading font-bold text-xl leading-tight mb-1">AI-Powered UI<br/>Generation</div>
              <div class="text-white/50 text-xs">siza.forgespace.co</div>
            </div>
          </div>
        </div>
      );
    })}
  </section>

  <!-- Status / Alert States -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">Status & Alert States</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="bg-[#0F0F14] rounded-xl p-4 space-y-2 border border-white/5">
          <div class="flex items-center gap-2 px-3 py-2 rounded-lg border" style={`border-color: ${p.accent}30; background: ${p.accent}10`}>
            <div class="w-1.5 h-1.5 rounded-full" style={`background: ${p.accent}`}></div>
            <span class="text-[10px]" style={`color: ${p.accent}`}>Generation limit reached — upgrade to Pro</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-lg border" style={`border-color: ${p.secondary}30; background: ${p.secondary}10`}>
            <div class="w-1.5 h-1.5 rounded-full" style={`background: ${p.secondary}`}></div>
            <span class="text-[10px]" style={`color: ${p.secondary}`}>New template pack available: SaaS Landing</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-lg border" style={`border-color: ${primary}30; background: ${primary}10`}>
            <div class="w-1.5 h-1.5 rounded-full" style={`background: ${primary}`}></div>
            <span class="text-[10px]" style={`color: ${primary}`}>Component saved to your library</span>
          </div>
          <div class="flex items-center gap-2 px-3 py-2 rounded-lg border border-red-500/30 bg-red-500/10">
            <div class="w-1.5 h-1.5 rounded-full bg-red-500"></div>
            <span class="text-[10px] text-red-400">Generation failed — try again</span>
          </div>
        </div>
      );
    })}
  </section>

  <!-- Form Inputs -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">Form Inputs & Focus States</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="space-y-3">
          <div class="bg-[#0F0F14] rounded-xl p-4 space-y-3 border border-white/5">
            <div>
              <label class="text-[9px] text-white/40 uppercase tracking-wider mb-1 block">Component Name</label>
              <div class="px-3 py-2 rounded-lg bg-white/5 border-2 text-[10px] text-white/80" style={`border-color: ${primary}`}>LoginForm</div>
            </div>
            <div>
              <label class="text-[9px] text-white/40 uppercase tracking-wider mb-1 block">Framework</label>
              <div class="flex gap-1.5">
                <span class="px-2.5 py-1 rounded-md text-[9px] font-medium text-white" style={`background: ${primary}`}>React</span>
                <span class="px-2.5 py-1 rounded-md text-[9px] text-white/40 bg-white/5">Vue</span>
                <span class="px-2.5 py-1 rounded-md text-[9px] text-white/40 bg-white/5">Svelte</span>
              </div>
            </div>
            <div>
              <label class="text-[9px] text-white/40 uppercase tracking-wider mb-1 block">Style</label>
              <div class="flex gap-1.5">
                <span class="px-2.5 py-1 rounded-md text-[9px] font-medium border" style={`color: ${p.secondary}; border-color: ${p.secondary}`}>Tailwind</span>
                <span class="px-2.5 py-1 rounded-md text-[9px] text-white/40 bg-white/5">CSS Modules</span>
              </div>
            </div>
            <button class="w-full py-2 rounded-lg text-[10px] font-bold text-white" style={`background: ${p.accent}`}>Generate Component</button>
          </div>

          <div class="bg-white rounded-xl p-4 space-y-3 border border-zinc-200">
            <div>
              <label class="text-[9px] text-zinc-400 uppercase tracking-wider mb-1 block">Email</label>
              <div class="px-3 py-2 rounded-lg border-2 text-[10px] text-zinc-700" style={`border-color: ${primary}`}>lucas@forgespace.co</div>
            </div>
            <div>
              <label class="text-[9px] text-zinc-400 uppercase tracking-wider mb-1 block">Plan</label>
              <div class="flex gap-1.5">
                <span class="px-2.5 py-1 rounded-md text-[9px] text-zinc-400 border border-zinc-200">Free</span>
                <span class="px-2.5 py-1 rounded-md text-[9px] font-medium text-white" style={`background: ${p.accent}`}>Pro</span>
                <span class="px-2.5 py-1 rounded-md text-[9px] text-zinc-400 border border-zinc-200">Team</span>
              </div>
            </div>
            <button class="w-full py-2 rounded-lg text-[10px] font-bold text-white" style={`background: ${primary}`}>Save Changes</button>
          </div>
        </div>
      );
    })}
  </section>

  <!-- Dashboard / Analytics -->
  <h2 class="text-xs text-text-muted uppercase tracking-wider mb-4">Dashboard / Analytics</h2>
  <section class="grid grid-cols-2 gap-6 mb-16">
    {ids.map((id) => {
      const p = palettes[id];
      return (
        <div class="bg-[#0F0F14] rounded-xl p-4 border border-white/5">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs font-heading font-bold text-white/80">Usage Overview</span>
            <span class="text-[9px] text-white/30 font-mono">March 2026</span>
          </div>

          <div class="grid grid-cols-3 gap-2 mb-4">
            <div class="bg-white/5 rounded-lg p-2.5">
              <div class="text-[9px] text-white/40 mb-0.5">Generations</div>
              <div class="text-sm font-heading font-bold" style={`color: ${primary}`}>247</div>
            </div>
            <div class="bg-white/5 rounded-lg p-2.5">
              <div class="text-[9px] text-white/40 mb-0.5">Templates</div>
              <div class="text-sm font-heading font-bold" style={`color: ${p.secondary}`}>18</div>
            </div>
            <div class="bg-white/5 rounded-lg p-2.5">
              <div class="text-[9px] text-white/40 mb-0.5">Saved</div>
              <div class="text-sm font-heading font-bold" style={`color: ${p.accent}`}>63</div>
            </div>
          </div>

          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="text-[9px] text-white/30 w-8 font-mono">React</span>
              <div class="flex-1 h-3 bg-white/5 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style={`width: 65%; background: ${primary}`}></div>
              </div>
              <span class="text-[9px] text-white/40 font-mono">65%</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[9px] text-white/30 w-8 font-mono">Vue</span>
              <div class="flex-1 h-3 bg-white/5 rounded-full overflow-hidden">
                <div class="h-full rounded-full" style={`width: 22%; background: ${p.secondary}`}></div>
              </div>
              <span class="text-[9px] text-white/40 font-mono">22%</span>
            </div>
