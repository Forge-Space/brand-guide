---
import BaseLayout from "@/layouts/BaseLayout.astro";
import identity from "../../brand/identity.json";

// ── From brand guide identity (single source of truth) ──────────
const palette = identity.brandDirection?.palette ?? { amber: "#A78BFA", blue: "#8B5CF6", purple: "#6D28D9" };
const gradient = identity.brandDirection?.gradientCss ?? identity.gradients?.presets?.hero?.cssValue ?? "linear-gradient(135deg, #6D28D9, #8B5CF6)";
const tagline = identity.tagline ?? "The developer tools ecosystem.";
const heroHeadline = identity.heroHeadline ?? "Build better, ship faster.";
const headingFont = identity.typography?.headingFont ?? "Sora";
const bodyFont = identity.typography?.bodyFont ?? "DM Sans";

const icon = identity.logo?.icon ?? `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
  <path d="M4 20 L18 14 H56 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H18 L4 24 V20Z" fill="${palette.amber}"/>
  <rect x="20" y="32" width="30" height="10" rx="3" fill="${palette.blue}"/>
  <rect x="14" y="48" width="40" height="14" rx="4" fill="${palette.purple}"/>
  <rect x="44" y="16" width="5" height="5" rx="1.5" fill="${palette.amber}" opacity="0.4"/>
</svg>`;

const iconWhite = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
  <path d="M4 20 L18 14 H56 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H18 L4 24 V20Z" fill="white" opacity="0.7"/>
  <rect x="20" y="32" width="30" height="10" rx="3" fill="white" opacity="0.85"/>
  <rect x="14" y="48" width="40" height="14" rx="4" fill="white"/>
  <rect x="44" y="16" width="5" height="5" rx="1.5" fill="white" opacity="0.3"/>
</svg>`;

const iconPurpleTint = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
  <path d="M4 20 L18 14 H56 a3 3 0 0 1 3 3 v6 a3 3 0 0 1-3 3 H18 L4 24 V20Z" fill="#C4B5FD"/>
  <rect x="20" y="32" width="30" height="10" rx="3" fill="${palette.blue}"/>
  <rect x="14" y="48" width="40" height="14" rx="4" fill="#5B21B6"/>
  <rect x="44" y="16" width="5" height="5" rx="1.5" fill="#C4B5FD" opacity="0.4"/>
</svg>`;

const sizes = [64, 48, 32, 24, 20, 16] as const;

const backgrounds = [
  { name: "App Dark", classes: "bg-surface-0", label: "text-white/40" },
  { name: "Surface", classes: "bg-surface-2", label: "text-white/40" },
  { name: "White", classes: "bg-white", label: "text-black/40" },
  { name: "Black", classes: "bg-black", label: "text-white/30" },
  { name: "Brand", classes: "", style: `background: ${palette.purple}`, label: "text-white/50" },
  { name: "Gradient", classes: "", style: gradient, label: "text-white/50" },
];

// ── Siza (from identity.subBrands.siza) ─────────────────────────
const siza = identity.subBrands?.siza ?? {};
const sc = siza.primaryColor ?? "#8B5CF6";
const cyan = siza.accentColor ?? "#06B6D4";
const sizaTagline = siza.tagline ?? "AI-powered code generation";
const sizaHeadingFont = siza.headingFont ?? "Plus Jakarta Sans";
const sizaBodyFont = siza.bodyFont ?? "DM Sans";

const sizaIcon = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
  <text x="3" y="48" font-family="'${sizaHeadingFont.replace(/"/g, "'")}', sans-serif" font-weight="700" font-size="42" fill="${sc}" letter-spacing="-3">Sz</text>
  <path d="M56 38 l1.5 4 4 1.5 -4 1.5 -1.5 4 -1.5-4 -4-1.5 4-1.5z" fill="${cyan}"/>
</svg>`;
---

<BaseLayout title="Brand Exploration — Modern Horn" wide>
  <header class="mb-16">
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xs font-mono text-text-muted bg-white/5 px-2 py-1 rounded">EXPLORATION</span>
      <span class="text-xs font-mono bg-purple-500/15 text-purple-300 px-2 py-1 rounded">MODERN HORN</span>
    </div>
    <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">Modern Horn — Monochrome</h1>
    <p class="text-text-secondary max-w-2xl text-lg">
      {identity.brandDirection?.description ?? "Modern Horn icon + monochrome purple palette + Sora / DM Sans typography."}
      Refining the chosen direction and exploring Siza sub-brand marks.
    </p>
  </header>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 1. HERO — Chosen Direction -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="mb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <!-- Dark card -->
      <div class="bg-surface-2 rounded-2xl border border-white/5 p-10 flex flex-col items-center justify-center">
        <div class="w-24 h-24 mb-6" set:html={icon} />
        <div style={`font-family: '${headingFont}', sans-serif`} class="text-2xl font-bold tracking-tight">FORGE SPACE</div>
        <div style={`font-family: '${bodyFont}', sans-serif`} class="text-xs text-text-secondary mt-1">{tagline}</div>
      </div>
      <!-- Light card -->
      <div class="bg-white rounded-2xl p-10 flex flex-col items-center justify-center">
        <div class="w-24 h-24 mb-6" set:html={icon} />
        <div style={`font-family: '${headingFont}', sans-serif`} class="text-2xl font-bold tracking-tight text-gray-900">FORGE SPACE</div>
        <div style={`font-family: '${bodyFont}', sans-serif`} class="text-xs text-gray-500 mt-1">{tagline}</div>
      </div>
      <!-- Gradient card -->
      <div class="rounded-2xl p-10 flex flex-col items-center justify-center" style={gradient}>
        <div class="w-24 h-24 mb-6" set:html={iconWhite} />
        <div style={`font-family: '${headingFont}', sans-serif`} class="text-2xl font-bold tracking-tight text-white">FORGE SPACE</div>
        <div style={`font-family: '${bodyFont}', sans-serif`} class="text-xs text-white/70 mt-1">{tagline}</div>
      </div>
    </div>

    <!-- Color reference -->
    <div class="bg-surface-1 rounded-xl p-4 flex items-center gap-6 text-xs font-mono text-text-muted">
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded" style={`background: ${palette.amber}`} />
        <span>{palette.amber}</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded" style={`background: ${palette.blue}`} />
        <span>{palette.blue}</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded" style={`background: ${palette.purple}`} />
        <span>{palette.purple}</span>
      </div>
      <span class="text-white/10">|</span>
      <span>H: {headingFont} &middot; B: {bodyFont}</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 2. VARIANTS — Color/White/Purple Tint -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="mb-24">
    <h2 class="font-heading text-xl font-bold mb-2">Mark Variants</h2>
    <p class="text-text-secondary text-sm mb-6">Full color, white (for dark/gradient backgrounds), and purple tint (monochrome).</p>

    <div class="grid grid-cols-3 gap-4 mb-8">
      <div>
        <div class="bg-surface-2 rounded-xl border border-white/5 p-8 flex items-center justify-center aspect-square">
          <div class="w-20 h-20" set:html={icon} />
        </div>
        <span class="text-[11px] font-mono text-text-muted mt-2 block text-center">Full Color</span>
      </div>
      <div>
        <div class="rounded-xl p-8 flex items-center justify-center aspect-square" style={gradient}>
          <div class="w-20 h-20" set:html={iconWhite} />
        </div>
        <span class="text-[11px] font-mono text-text-muted mt-2 block text-center">White</span>
      </div>
      <div>
        <div class="bg-white rounded-xl p-8 flex items-center justify-center aspect-square">
          <div class="w-20 h-20" set:html={iconPurpleTint} />
        </div>
        <span class="text-[11px] font-mono text-text-muted mt-2 block text-center">Purple Tint</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 3. SIZE SCALING -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="mb-24">
    <h2 class="font-heading text-xl font-bold mb-2">Size Scaling</h2>
    <p class="text-text-secondary text-sm mb-6">Does the mark hold at small sizes?</p>

    <div class="space-y-4">
      <div class="bg-surface-2 rounded-xl p-8 border border-white/5">
        <span class="text-[10px] text-text-muted font-mono uppercase tracking-wider mb-4 block">Dark</span>
        <div class="flex items-end gap-6">
          {sizes.map(s => (
            <div class="text-center">
              <div style={`width: ${s}px; height: ${s}px`} set:html={icon} />
              <span class="text-[8px] text-text-muted font-mono mt-1 block">{s}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-white rounded-xl p-8">
        <span class="text-[10px] text-black/40 font-mono uppercase tracking-wider mb-4 block">Light</span>
        <div class="flex items-end gap-6">
          {sizes.map(s => (
            <div class="text-center">
              <div style={`width: ${s}px; height: ${s}px`} set:html={icon} />
              <span class="text-[8px] text-black/30 font-mono mt-1 block">{s}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 4. BACKGROUND MATRIX -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="mb-24">
    <h2 class="font-heading text-xl font-bold mb-2">Background Matrix</h2>
    <p class="text-text-secondary text-sm mb-6">The mark on every surface.</p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {backgrounds.map(bg => (
        <div class={`rounded-xl p-8 flex flex-col items-center justify-center aspect-video ${bg.classes}`} style={bg.style ?? ""}>
          <div class="w-12 h-12 mb-2" set:html={bg.name === "Brand" || bg.name === "Gradient" ? iconWhite : icon} />
          <span class={`text-[10px] font-mono ${bg.label}`}>{bg.name}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 5. IN-CONTEXT PREVIEWS -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="mb-24">
    <h2 class="font-heading text-xl font-bold mb-2">In Context</h2>
    <p class="text-text-secondary text-sm mb-6">How it looks in real UI.</p>

    <div class="space-y-4">
      <!-- Nav dark -->
      <div class="bg-surface-1 rounded-xl px-6 py-4 flex items-center gap-4 border border-white/5">
        <div class="w-8 h-8" set:html={icon} />
        <span style={`font-family: '${headingFont}', sans-serif`} class="font-bold text-sm">Forge Space</span>
        <div class="flex-1" />
        <span class="text-xs text-text-muted">Dashboard</span>
        <span class="text-xs text-text-muted">Generate</span>
        <span class="text-xs text-text-muted">Docs</span>
      </div>

      <!-- Nav light -->
      <div class="bg-white rounded-xl px-6 py-4 flex items-center gap-4">
        <div class="w-8 h-8" set:html={icon} />
        <span style={`font-family: '${headingFont}', sans-serif`} class="font-bold text-sm text-gray-900">Forge Space</span>
        <div class="flex-1" />
        <span class="text-xs text-gray-500">Dashboard</span>
        <span class="text-xs text-gray-500">Generate</span>
        <span class="text-xs text-gray-500">Docs</span>
      </div>

      <!-- Hero banner -->
      <div class="rounded-xl p-12 flex flex-col items-center justify-center text-center" style={gradient}>
        <div class="w-16 h-16 mb-4" set:html={iconWhite} />
        <span style={`font-family: '${headingFont}', sans-serif`} class="font-bold text-2xl text-white">Forge Space</span>
        <span style={`font-family: '${bodyFont}', sans-serif`} class="text-sm text-white/70 mt-1">{heroHeadline}</span>
      </div>

      <!-- Footer -->
      <div class="bg-black rounded-xl px-8 py-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-6 h-6" set:html={iconWhite} />
          <span style={`font-family: '${headingFont}', sans-serif`} class="text-xs text-white/50 font-medium">Forge Space</span>
        </div>
        <span class="text-xs text-white/30 font-mono">2026</span>
      </div>

      <!-- App icons -->
      <div class="flex gap-4 mt-4">
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-surface-2 border border-white/5 flex items-center justify-center p-3">
            <div class="w-10 h-10" set:html={icon} />
          </div>
          <span class="text-[9px] text-text-muted font-mono mt-2 block">Dark</span>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center p-3">
            <div class="w-10 h-10" set:html={icon} />
          </div>
          <span class="text-[9px] text-text-muted font-mono mt-2 block">Light</span>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center p-3" style={`background: ${palette.purple}`}>
            <div class="w-10 h-10" set:html={iconWhite} />
          </div>
          <span class="text-[9px] text-text-muted font-mono mt-2 block">Brand</span>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center p-3" style={gradient}>
            <div class="w-10 h-10" set:html={iconWhite} />
          </div>
          <span class="text-[9px] text-text-muted font-mono mt-2 block">Gradient</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 6. SIZA — Sz + Cyan Spark (LOCKED) -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="mb-24" id="siza">
    <div class="flex items-center gap-4 mb-2">
      <div class="w-3 h-3 rounded-full" style={`background: ${cyan}`} />
      <h2 class="font-heading text-2xl font-bold">Siza — Sz + Cyan Spark</h2>
      <span class="text-xs font-mono bg-cyan-500/15 text-cyan-300 px-2 py-1 rounded">LOCKED</span>
    </div>
    <p class="text-text-secondary mb-8 max-w-xl">
      "Sz" lettermark in Sora Bold + cyan 4-point spark accent.
      Sub-brand of Forge Space — clean, typographic, recognizable.
    </p>

    <!-- Icon previews -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      <div class="bg-surface-2 rounded-2xl border border-white/5 p-10 flex flex-col items-center justify-center">
        <div class="w-24 h-24 mb-4" set:html={sizaIcon} />
        <div style={`font-family: '${sizaHeadingFont}', sans-serif`} class="text-xl font-bold tracking-tight">Siza</div>
        <div style={`font-family: '${sizaBodyFont}', sans-serif`} class="text-[11px] text-text-secondary mt-0.5">{sizaTagline}</div>
      </div>
      <div class="bg-white rounded-2xl p-10 flex flex-col items-center justify-center">
        <div class="w-24 h-24 mb-4" set:html={sizaIcon} />
        <div style={`font-family: '${sizaHeadingFont}', sans-serif`} class="text-xl font-bold tracking-tight text-gray-900">Siza</div>
        <div style={`font-family: '${sizaBodyFont}', sans-serif`} class="text-[11px] text-gray-500 mt-0.5">{sizaTagline}</div>
      </div>
      <div class="rounded-2xl p-10 flex flex-col items-center justify-center" style={`background: ${sc}`}>
        <div class="w-24 h-24 mb-4 [&_text]:!fill-white" set:html={sizaIcon} />
        <div style={`font-family: '${sizaHeadingFont}', sans-serif`} class="text-xl font-bold tracking-tight text-white">Siza</div>
        <div style={`font-family: '${sizaBodyFont}', sans-serif`} class="text-[11px] text-white/70 mt-0.5">{sizaTagline}</div>
      </div>
    </div>

    <!-- Size scaling -->
    <h3 class="text-xs font-mono text-text-muted uppercase tracking-wider mb-4">Size Scaling</h3>
    <div class="bg-surface-2 rounded-xl p-8 border border-white/5 mb-4">
      <div class="flex items-end gap-6">
        {sizes.map(s => (
          <div class="text-center">
            <div style={`width: ${s}px; height: ${s}px`} set:html={sizaIcon} />
            <span class="text-[8px] text-text-muted font-mono mt-1 block">{s}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Color reference -->
    <div class="bg-surface-1 rounded-xl p-4 flex items-center gap-6 text-xs font-mono text-text-muted">
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded" style={`background: ${sc}`} />
        <span>{sc} Purple</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-4 h-4 rounded" style={`background: ${cyan}`} />
        <span>{cyan} Cyan Spark</span>
      </div>
      <span class="text-white/10">|</span>
      <span>H: {sizaHeadingFont} &middot; B: {sizaBodyFont} &middot; M: {siza.monoFont ?? "IBM Plex Mono"}</span>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- 7. PAIRED — Forge Space | Siza -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="mb-24">
    <h3 class="font-heading text-lg font-bold mb-2">Forge Space | Siza</h3>
    <p class="text-text-secondary text-sm mb-6">Parent and sub-brand paired together.</p>

    <div class="space-y-4">
      <div class="bg-surface-1 rounded-xl px-6 py-3 flex items-center gap-4 border border-white/5">
        <div class="w-6 h-6 shrink-0" set:html={icon} />
        <span style={`font-family: '${headingFont}', sans-serif`} class="font-bold text-sm">Forge Space</span>
        <span class="text-white/15">|</span>
        <div class="w-6 h-6 shrink-0" set:html={sizaIcon} />
        <span style={`font-family: '${sizaHeadingFont}', sans-serif`} class="font-semibold text-sm text-text-secondary">Siza</span>
        <div class="flex-1" />
        <span class="text-xs text-text-muted">Dashboard</span>
        <span class="text-xs text-text-muted">Generate</span>
      </div>

      <div class="bg-white rounded-xl px-6 py-3 flex items-center gap-4">
        <div class="w-6 h-6 shrink-0" set:html={icon} />
        <span style={`font-family: '${headingFont}', sans-serif`} class="font-bold text-sm text-gray-900">Forge Space</span>
        <span class="text-gray-200">|</span>
        <div class="w-6 h-6 shrink-0" set:html={sizaIcon} />
        <span style={`font-family: '${sizaHeadingFont}', sans-serif`} class="font-semibold text-sm text-gray-500">Siza</span>
        <div class="flex-1" />
        <span class="text-xs text-gray-400">Dashboard</span>
        <span class="text-xs text-gray-400">Generate</span>
      </div>

      <div class="bg-surface-2 rounded-xl border border-white/5 p-6">
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10" set:html={icon} />
            <div style={`font-family: '${headingFont}', sans-serif`} class="text-lg font-bold tracking-tight">FORGE SPACE</div>
          </div>
          <span class="text-white/10">|</span>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8" set:html={sizaIcon} />
            <div style={`font-family: '${sizaHeadingFont}', sans-serif`} class="text-lg font-bold tracking-tight">Siza</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <div class="bg-surface-2 rounded-xl border border-white/5 p-6 text-sm text-text-secondary">
    <p class="font-heading font-bold text-text-primary mb-2">Modern Horn — Exploration</p>
    <p class="text-xs mb-3">
      Forge Space: <strong>{identity.brandDirection?.name ?? "Modern Horn"} + Monochrome + {headingFont}/{bodyFont}</strong><br/>
      Siza: <strong>Sz + Cyan Spark + {sizaHeadingFont}/{sizaBodyFont}</strong>
    </p>
  </div>
</BaseLayout>